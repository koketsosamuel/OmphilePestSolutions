---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  image,
  noindex = false,
} = Astro.props;

const siteBase = Astro.site ?? new URL(site.url);
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const socialImage = new URL(image ?? '/hero-pest-control.jpg', siteBase);
const logoURL = new URL('/Logo.png', siteBase);
const isProduction = import.meta.env.PROD;

const ld = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  url: siteBase.href,
  logo: logoURL.href,
  image: socialImage.href,
  telephone: site.phone,
  email: site.email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Mafikeng',
    addressRegion: 'North West',
    addressCountry: 'ZA',
  },
  areaServed: ['North West', 'Gauteng', 'South Africa'],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '08:00',
      closes: '13:00',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage.href} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_ZA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage.href} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="512x512" href="/Omphile Pest Favicon.png" />
    <title>{title}</title>

    <!-- JSON-LD structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />

    {isProduction && (
      <>
        <link rel="preconnect" href={site.analytics.host} />
        <link rel="dns-prefetch" href={site.analytics.host} />
        <script is:inline defer src={site.analytics.scriptSrc} data-website-id={site.analytics.websiteId}></script>
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
