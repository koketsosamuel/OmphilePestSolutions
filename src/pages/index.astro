---
import Layout from '../layouts/Layout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<Layout title="Omphile Pest Solutions – Trusted Pest Control Across Gauteng">
  <UtilityBar />
  <Navbar />

  <!-- Hero Section -->
  <div class="hero-wrapper">
  <div class="container hero">
    <div class="hero-left">
      <span class="overline">TRUSTED PEST CONTROL ACROSS GAUTENG</span>
      <div class="headline-wrap">
        <div class="headline-line1">
          <h1 class="headline-text">Your <span class="headline-highlight" id="typing-word">home</span></h1>
        </div>
        <p class="headline-line2">deserves better than pests.</p>
      </div>
      <p class="hero-sub">From Northwest to Gauteng, Omphile Pest Solutions delivers fast, thorough, and responsible pest control. We protect what matters most — your family, your home, your pets, and the environment we all share.</p>
      <div class="hero-ctas">
        <a href="#quote" class="btn-primary">Get a Free Quote</a>
        <a href="tel:+27762805241" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call Now: +27 76 280 5241
        </a>
      </div>
      <div class="trust-strip">
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span>B-BBEE Compliant</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span>SAPCA Registered</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
          <span>Years of Proven Experience</span>
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>Thousands of Homes Protected</span>
        </div>
      </div>
    </div>
    <div class="hero-image">
      <img src="https://images.unsplash.com/photo-1759412393800-0ac06909423a?w=600&q=80" alt="Professional pest control technician" />
    </div>
  </div>
  </div>

  <!-- Problem Section -->
  <section class="section section--bg-white"><div class="container problem-section">
    <SectionHeading
      label="WHY ACT NOW"
      labelColor="amber"
      title="Pests do not wait. Neither should you."
      subtitle="Every day without professional treatment gives pests more time to breed, spread disease, and cause structural damage that costs thousands to repair. Early intervention is always more effective — and far less expensive — than dealing with a full-blown infestation."
      align="center"
      maxWidth="700px"
    />
    <div class="problem-cards">
      <div class="problem-card">
        <div class="card-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <h3 class="card-title">Property Damage</h3>
        <p class="card-desc">Termites alone cause billions of rands in property damage across South Africa each year. By the time you see the signs, the damage is already extensive.</p>
      </div>
      <div class="problem-card">
        <div class="card-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg></div>
        <h3 class="card-title">Health Risks</h3>
        <p class="card-desc">Cockroaches and rats carry dangerous pathogens including salmonella, E. coli, and allergens that trigger asthma — especially in children and the elderly.</p>
      </div>
      <div class="problem-card">
        <div class="card-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg></div>
        <h3 class="card-title">Business Compliance</h3>
        <p class="card-desc">A single pest sighting can shut down a restaurant or warehouse. South African health regulations require documented pest management for all food-handling businesses.</p>
      </div>
    </div>
  </div></section>

  <!-- Who We Serve -->
  <section class="section"><div class="container who-we-serve">
    <SectionHeading
      label="WHO WE SERVE"
      title="From family homes to government facilities."
      subtitle="Whether you're a homeowner dealing with a once-off infestation, a facilities manager maintaining compliance, or a government department requiring tender-ready pest management — we have a solution built for you."
      align="center"
      size="lg"
      maxWidth="720px"
    />
    <div class="serve-cards">
      <div class="serve-card">
        <div class="serve-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
        <h3 class="serve-title">Homeowners</h3>
        <p class="serve-desc">One-off treatments with fast response times. Every job comes with a written guarantee so you can rest easy knowing your home is protected.</p>
        <a href="#quote" class="serve-cta">Get a Quote →</a>
      </div>
      <div class="serve-card">
        <div class="serve-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg></div>
        <h3 class="serve-title">Private Companies</h3>
        <p class="serve-desc">Ongoing contracts with compliance reports and a dedicated account manager. We keep your facilities pest-free so you can focus on business.</p>
        <a href="#quote" class="serve-cta">Request a Contract →</a>
      </div>
      <div class="serve-card">
        <div class="serve-icon-wrap"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><path d="M2 20h20"/><path d="M5 20V8.2c0-.4.2-.7.5-.9l6-3.6a1 1 0 0 1 1 0l6 3.6c.3.2.5.5.5.9V20"/><path d="M12 4v16"/><path d="M2 12h20"/></svg></div>
        <h3 class="serve-title">Government & Public Sector</h3>
        <p class="serve-desc">B-BBEE compliant, CSD registered, and tender-ready. We meet every requirement so you can award with confidence.</p>
        <a href="#quote" class="serve-cta">Get in Touch →</a>
      </div>
    </div>
    <div class="bbee-banner">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
      <span>Proudly B-BBEE Level 1 Compliant  ·  CSD Registered  ·  Tender-Ready</span>
    </div>
  </div></section>

  <!-- Services Section -->
  <section id="services" class="section section--bg-stone"><div class="container services-section">
    <SectionHeading
      label="WHAT WE DO"
      title="Comprehensive pest control, no half measures."
      subtitle="Every property is different. We tailor our service to your specific pest challenge, using safe, environmentally responsible methods backed by decades of field experience. We never use more than what's needed — because protecting your space shouldn't come at the cost of the world around it."
      align="center"
      size="lg"
      maxWidth="720px"
    />
    <div class="services-grid">
      <div class="services-row">
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="m8 2 1.88 1.88"/><path d="M14.12 3.88 16 2"/><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"/><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"/><path d="M12 20v-9"/><path d="M6.53 9C4.6 8.8 3 7.1 3 5"/><path d="M6 13H2"/><path d="M3 21c0-2.1 1.7-3.9 3.8-4"/><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"/><path d="M22 13h-4"/><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"/></svg><h4>Termite Control</h4><p>Pre- and post-construction barrier treatments to protect your structure from silent damage.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="m8 2 1.88 1.88"/><path d="M14.12 3.88 16 2"/><path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1"/><path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6"/><path d="M12 20v-9"/><path d="M6.53 9C4.6 8.8 3 7.1 3 5"/><path d="M6 13H2"/><path d="M3 21c0-2.1 1.7-3.9 3.8-4"/><path d="M20.97 5c0 2.1-1.6 3.8-3.5 4"/><path d="M22 13h-4"/><path d="M17.2 17c2.1.1 3.8 1.9 3.8 4"/><line x1="2" y1="2" x2="22" y2="22"/></svg><h4>Cockroach Treatment</h4><p>Gel baiting and residual sprays targeting German, American, and Oriental species.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M14 16.5a2.5 2.5 0 0 0-5 0"/><path d="M3 2c.1 3.3 1.2 6.5 3 9.3"/><path d="M9 7.5c.8.8 1.4 1.8 1.8 2.8"/><path d="M21 2c-.1 3.3-1.2 6.5-3 9.3"/><path d="M15 7.5c-.8.8-1.4 1.8-1.8 2.8"/><path d="M12 13c-1 0-2 .4-2.7 1.1"/><path d="M12 13c1 0 2 .4 2.7 1.1"/><path d="M8.5 16.5c0 .8.1 1.6.4 2.3"/><path d="M15.5 16.5c0 .8-.1 1.6-.4 2.3"/><path d="M9 22h6"/></svg><h4>Rodent Control</h4><p>Humane bait stations, traps, and exclusion methods for rats and mice — focused on removal and prevention, not unnecessary harm.</p><a href="#services">Learn more →</a></div>
      </div>
      <div class="services-row">
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><h4>Mosquito & Fly Control</h4><p>Fogging, larviciding, and fly traps for commercial kitchens, warehouses, and outdoor areas.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg><h4>Bed Bug Treatment</h4><p>Heat and chemical treatments that eliminate bed bugs at every life stage — eggs included.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M16 7h.01"/><path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/><path d="m20 7 2 .5-2 .5"/><path d="M10 18v3"/><path d="M14 17.75V21"/><path d="M7 18a6 6 0 0 0 3.84-10.61"/></svg><h4>Bird Control</h4><p>Humane netting, spikes, and deterrent systems that redirect pigeons and starlings away from commercial properties — without harming them.</p><a href="#services">Learn more →</a></div>
      </div>
      <div class="services-row">
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg><h4>Fumigation</h4><p>Full-structure fumigation for severe infestations in warehouses, silos, and storage facilities.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg><h4>Weed & Vegetation Control</h4><p>Careful herbicide application and vegetation management for pavements, fences, and open land — with low-toxicity products chosen to minimise soil and water impact.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M12 7.5a4.5 4.5 0 1 1 4.5 4.5M12 7.5A4.5 4.5 0 1 0 7.5 12M12 7.5V9m-4.5 3H9"/><path d="M7.5 12a4.5 4.5 0 1 0 4.5 4.5M7.5 12H9"/><path d="M12 16.5a4.5 4.5 0 1 1 4.5-4.5M12 16.5V15"/><path d="M16.5 12a4.5 4.5 0 1 0-4.5-4.5M16.5 12H15"/></svg><h4>Lawn & Garden Pests</h4><p>Targeted treatments for lawn grubs, aphids, snails, and other garden invaders — carefully applied to protect pollinators and beneficial insects.</p><a href="#services">Learn more →</a></div>
      </div>
      <div class="services-row">
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg><h4>Sanitation Services</h4><p>Deep cleaning and sanitisation for kitchens, bathrooms, and high-traffic commercial spaces.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1B3A2D" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg><h4>Government & Contract Services</h4><p>Scheduled pest management programmes for schools, hospitals, housing, and municipal buildings.</p><a href="#services">Learn more →</a></div>
        <div class="svc-card empty"></div>
      </div>
    </div>
    <div class="services-cta-wrap">
      <p class="services-cta-text">Not sure what you need?</p>
      <a href="#quote" class="btn-primary btn-lg">Get a Free Quote</a>
    </div>
  </div></section>

  <!-- How It Works -->
  <section class="section"><div class="container how-it-works">
    <SectionHeading
      label="OUR PROCESS"
      title="Four steps. No surprises."
      subtitle="Our methodical, transparent process means you always know what's happening, what it costs, and what to expect — before we begin."
      align="center"
      maxWidth="600px"
    />
    <div class="steps-timeline">
      <div class="step">
        <div class="step-circle"><span>01</span></div>
        <h4 class="step-title">Inspection</h4>
        <p class="step-desc">We visit your property, identify pest activity, entry points, and risk areas.</p>
      </div>
      <div class="step-line"></div>
      <div class="step">
        <div class="step-circle"><span>02</span></div>
        <h4 class="step-title">Custom Plan</h4>
        <p class="step-desc">A written treatment plan with transparent pricing and product choices explained — no hidden costs, no surprises, no unnecessary chemicals.</p>
      </div>
      <div class="step-line"></div>
      <div class="step">
        <div class="step-circle"><span>03</span></div>
        <h4 class="step-title">Treatment</h4>
        <p class="step-desc">Certified technicians apply SAPCA-approved, low-impact products safely and effectively — always with your family, pets, and the surrounding environment in mind.</p>
      </div>
      <div class="step-line"></div>
      <div class="step">
        <div class="step-circle"><span>04</span></div>
        <h4 class="step-title">Follow-Up</h4>
        <p class="step-desc">We come back, check results, and provide a written guarantee for your peace of mind.</p>
      </div>
    </div>
  </div></section>

  <!-- Testimonials -->
  <section class="section"><div class="container testimonials">
    <SectionHeading
      label="WHAT OUR CLIENTS SAY"
      title="Trusted by homeowners, businesses, and government across South Africa."
      align="center"
      maxWidth="800px"
    />
    <div class="testimonial-grid">
      <div class="testimonial-card">
        <span class="quote-icon-sm">&ldquo;</span>
        <p class="quote-text-sm">Omphile Pest Solutions has been managing pest control across our portfolio of residential complexes for years now. Their consistency, professionalism, and transparent reporting make them an invaluable partner.</p>
        <p class="quote-attr-sm">— Thandi Mokoena, Property Manager, Johannesburg</p>
      </div>
      <div class="testimonial-card">
        <span class="quote-icon-sm">&ldquo;</span>
        <p class="quote-text-sm">We discovered termites in our roof beams. Omphile Pest Solutions came out the next day, explained everything clearly, and treated the entire structure. To this day — not a single sign of return.</p>
        <p class="quote-attr-sm">— David van der Merwe, Homeowner, Pretoria</p>
      </div>
      <div class="testimonial-card">
        <span class="quote-icon-sm">&ldquo;</span>
        <p class="quote-text-sm">As a restaurant owner, passing health inspections is non-negotiable. Omphile's monthly service and documentation have kept us compliant year after year without a single issue.</p>
        <p class="quote-attr-sm">— Sipho Nkosi, Restaurant Owner, Durban</p>
      </div>
      <div class="testimonial-card">
        <span class="quote-icon-sm">&ldquo;</span>
        <p class="quote-text-sm">Called on a Friday evening about rats in our ceiling. Omphile had someone at our door by Saturday morning. Professional, thorough, and genuinely caring. Can't recommend them enough.</p>
        <p class="quote-attr-sm">— Lerato Dlamini, Homeowner, Cape Town</p>
      </div>
      <div class="testimonial-card">
        <span class="quote-icon-sm">&ldquo;</span>
        <p class="quote-text-sm">As a government procurement officer, B-BBEE compliance is a requirement. Omphile's Level 1 status and impeccable documentation made the decision easy. They deliver on every contract.</p>
        <p class="quote-attr-sm">— Nomvula Khumalo, Procurement Officer, Gauteng</p>
      </div>
    </div>
    <div class="trust-logos">
      <span>SAPCA</span><span>B-BBEE LEVEL 1</span><span>SABS</span>
    </div>
  </div></section>

  <!-- Stats -->
  <section class="section--sm section--bg-stone"><div class="container stats-section">
    <div class="stat"><span class="stat-num">Years</span><span class="stat-label">Of trusted service</span></div>
    <div class="stat"><span class="stat-num">Thousands</span><span class="stat-label">Of homes and businesses</span></div>
    <div class="stat"><span class="stat-num">Tens of Thousands</span><span class="stat-label">Of treatments completed</span></div>
    <div class="stat"><span class="stat-num">Top Rated</span><span class="stat-label">On Google</span></div>
  </div></section>

  <!-- Areas We Cover -->
  <section id="areas" class="section"><div class="container areas-section">
    <SectionHeading
      label="SERVICE AREAS"
      title="Based in North West. Serving all nine provinces."
      subtitle="Our headquarters are in North West, with teams covering Gauteng, Limpopo, Mpumalanga, Free State, and beyond. No matter where you are in South Africa, we'll get to you."
      align="center"
      maxWidth="700px"
    />
    <div class="map-placeholder">
      <div class="map-ring ring-outer"></div>
      <div class="map-ring ring-inner"></div>
      <div class="map-ring-stroke ring-stroke-outer"></div>
      <div class="map-ring-stroke ring-stroke-inner"></div>
      <div class="map-pill hq float-1" style="top:30%;left:28%">
        <span class="map-dot white"></span>North West
        <span class="hq-label">HQ</span>
      </div>
      <div class="map-pill float-2" style="top:30%;left:52%"><span class="map-dot"></span>Gauteng</div>
      <div class="map-pill float-3" style="top:10%;left:40%"><span class="map-dot"></span>Limpopo</div>
      <div class="map-pill float-4" style="top:18%;left:62%"><span class="map-dot"></span>Mpumalanga</div>
      <div class="map-pill float-5" style="top:50%;left:48%"><span class="map-dot"></span>Free State</div>
