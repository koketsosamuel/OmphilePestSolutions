---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Services – Omphile Pest Solutions">
  <Navbar activePage="services" />
  <div class="nav-divider"></div>

  <!-- Page Header -->
  <section class="page-header">
    <h1 class="header-title">Services</h1>
    <p class="header-sub">A comprehensive range of pest control solutions for every need</p>
    <div class="header-divider"></div>
  </section>

  <!-- Category Filters -->
  <section class="filters">
    <div class="filter-tab active">
      <span>RESIDENTIAL</span>
      <div class="tab-line"></div>
    </div>
    <span class="filter-tab-text">COMMERCIAL</span>
    <span class="filter-tab-text">TERMITE</span>
    <span class="filter-tab-text">FUMIGATION</span>
    <span class="filter-tab-text">RODENT</span>
  </section>

  <!-- Services Grid -->
  <section class="services-grid">
    <div class="services-row">
      <div class="service-item">
        <div class="service-img" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">RESIDENTIAL</span>
          <h3 class="service-name">General Pest Control</h3>
          <p class="service-loc">Cockroaches, ants, spiders & more</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-img" style="background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">COMMERCIAL</span>
          <h3 class="service-name">Office & Retail</h3>
          <p class="service-loc">Scheduled maintenance programs</p>
        </div>
      </div>
    </div>
    <div class="services-row triple">
      <div class="service-item">
        <div class="service-img tall" style="background-image: url('https://images.unsplash.com/photo-1585314062340-f1a5a7c9328d?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">SPECIALIST</span>
          <h3 class="service-name">Termite Inspection</h3>
          <p class="service-loc">Pre-purchase & annual inspections</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-img tall" style="background-image: url('https://images.unsplash.com/photo-1632935190593-e18460fa1534?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">FUMIGATION</span>
          <h3 class="service-name">Structural Fumigation</h3>
          <p class="service-loc">Complete property treatment</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-img tall" style="background-image: url('https://images.unsplash.com/photo-1585429514710-67f0ece1226e?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">RODENT</span>
          <h3 class="service-name">Rodent Management</h3>
          <p class="service-loc">Rats, mice & wildlife removal</p>
        </div>
      </div>
    </div>
    <div class="services-row">
      <div class="service-item">
        <div class="service-img" style="background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">RESIDENTIAL</span>
          <h3 class="service-name">Bed Bug Treatment</h3>
          <p class="service-loc">Heat & chemical treatment options</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-img" style="background-image: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&q=80')"></div>
        <div class="service-detail">
          <span class="service-cat">COMMERCIAL</span>
          <h3 class="service-name">Restaurant & Food Service</h3>
          <p class="service-loc">Health compliance guaranteed</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .nav-divider { height: 1px; background: var(--surface-linen); }

  .page-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 80px 56px 48px;
  }

  .header-title { font-family: var(--font-display); font-size: 72px; color: var(--text-primary); font-weight: 400; }
  .header-sub { font-family: var(--font-body); font-size: 18px; font-weight: 300; color: var(--text-secondary); text-align: center; }
  .header-divider { width: 60px; height: 2px; background: var(--accent-gold); }

  .filters {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    padding: 0 56px 48px;
  }

  .filter-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .filter-tab span, .filter-tab-text {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.3s;
  }

  .filter-tab.active span { color: var(--accent-gold); font-weight: 500; }
  .tab-line { width: 100%; height: 2px; background: var(--accent-gold); }
  .filter-tab-text:hover { color: var(--accent-gold); }

  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 0 56px 48px;
  }

  .services-row { display: flex; gap: 24px; }
  .service-item { flex: 1; display: flex; flex-direction: column; gap: 12px; }
  .service-img { width: 100%; height: 450px; background-size: cover; background-position: center; }
  .service-img.tall { height: 350px; }

  .service-detail { display: flex; flex-direction: column; gap: 4px; }
  .service-cat { font-family: var(--font-body); font-size: 10px; font-weight: 500; letter-spacing: 3px; color: var(--accent-gold); }
  .service-name { font-family: var(--font-display); font-size: 20px; color: var(--text-primary); font-weight: 400; }
  .service-loc { font-family: var(--font-body); font-size: 12px; color: var(--text-secondary); }

  @media (max-width: 768px) {
    .page-header { padding: 48px 24px 32px; }
    .header-title { font-size: 40px; }
    .filters { flex-wrap: wrap; gap: 16px; padding: 0 24px 32px; }
    .services-grid { padding: 0 24px 32px; }
    .services-row { flex-direction: column; }
    .service-img { height: 280px; }
    .service-img.tall { height: 280px; }
  }
</style>
