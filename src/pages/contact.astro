---
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import SectionHeading from '../components/SectionHeading.astro';
import UtilityBar from '../components/UtilityBar.astro';
import { site } from '../data/site';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Omphile Pest Solutions" description="Contact Omphile Pest Solutions for pest control quotes, inspections, WhatsApp enquiries, and commercial pest management support.">
  <UtilityBar />
  <Navbar />

  <section class="page-hero">
    <div class="container page-hero__grid">
      <div class="page-hero__content">
        <span class="page-kicker">CONTACT</span>
        <h1 class="page-title">Tell us what is happening on your property.</h1>
        <p class="page-lede">Send the details you have: pest type, location, property type, photos if you follow up by WhatsApp, and how quickly you need help.</p>
        <div class="contact-list contact-list--featured">
          <a class="contact-card-link" href={`tel:${site.phone}`}>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span class="contact-copy">
              <span class="contact-label">Call</span>
              <span class="contact-value">{site.phoneDisplay}</span>
            </span>
          </a>
          <a class="contact-card-link" href={site.whatsapp} target="_blank" rel="noopener noreferrer">
            <span class="contact-icon contact-icon--whatsapp" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L2 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </span>
            <span class="contact-copy">
              <span class="contact-label">WhatsApp</span>
              <span class="contact-value">Message Omphile Pest Solutions</span>
            </span>
          </a>
          <a class="contact-card-link" href={`mailto:${site.email}`}>
            <span class="contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            <span class="contact-copy">
              <span class="contact-label">Email</span>
              <span class="contact-value">{site.email}</span>
            </span>
          </a>
        </div>
      </div>
      <div class="page-hero__image">
        <img src="/hero-pest-control.jpg" alt="Pest control technician ready to respond to a service enquiry" />
      </div>
    </div>
  </section>

  <section class="page-section page-section--stone">
    <div class="container page-section__stack contact-form-stack">
      <SectionHeading
        label="REQUEST A QUOTE"
        title="Use the form and we will come back to you."
        subtitle="Your enquiry is sent to the Brightsync Hub contact submissions API so the team can follow up from one place."
        align="center"
        maxWidth="720px"
      />
      <ContactForm />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-form-stack {
    align-items: center;
  }

  .contact-list--featured {
    gap: 14px;
    max-width: 520px;
  }

  .contact-card-link {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 16px;
    background: var(--white);
    border: 1px solid var(--border-mist);
    border-radius: 8px;
    box-shadow: 0 12px 28px rgba(27, 58, 45, .06);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }

  .contact-card-link:hover {
    transform: translateY(-2px);
    border-color: rgba(76, 175, 80, .45);
    box-shadow: 0 16px 34px rgba(27, 58, 45, .1);
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--primary-deep-forest);
    background: rgba(27, 58, 45, .07);
    flex-shrink: 0;
  }

  .contact-icon--whatsapp {
    color: #0F7A38;
    background: rgba(37, 211, 102, .14);
  }

  .contact-icon svg {
    width: 22px;
    height: 22px;
  }

  .contact-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.6px;
    color: var(--accent-sap-green);
    text-transform: uppercase;
  }

  .contact-value {
    font-size: 15px;
    font-weight: 700;
    color: var(--primary-deep-forest);
    overflow-wrap: anywhere;
  }

  @media (max-width: 575.98px) {
    .contact-card-link {
      align-items: flex-start;
      padding: 14px;
    }
  }
</style>
