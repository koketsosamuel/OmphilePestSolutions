---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact – Omphile Pest Solutions">
  <Navbar activePage="contact" />
  <div class="nav-divider"></div>

  <!-- Contact Main -->
  <section class="contact-main">
    <div class="contact-left">
      <h1 class="contact-heading">Let's Protect<br>Your Property</h1>
      <p class="contact-subtitle">Whether it's a residential home, office, or warehouse — we'd love to help you stay pest-free.</p>

      <div class="dot-accent">
        <span class="dot gold"></span>
        <span class="dot terracotta"></span>
        <span class="dot gold"></span>
      </div>

      <div class="contact-gold-line"></div>

      <!-- Contact Info Card -->
      <div class="contact-info-card">
        <div class="info-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>+27 12 345 6789</span>
        </div>
        <div class="info-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>info@omphilepestsolutions.co.za</span>
        </div>
        <div class="info-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Johannesburg, Gauteng</span>
        </div>
      </div>

      <!-- Contact Form -->
      <form class="contact-form">
        <div class="form-field">
          <label>FULL NAME</label>
          <input type="text" placeholder="Your name" />
          <div class="field-line"></div>
        </div>
        <div class="form-field">
          <label>EMAIL</label>
          <input type="email" placeholder="your@email.com" />
          <div class="field-line"></div>
        </div>
        <div class="form-field">
          <label>PHONE</label>
          <input type="tel" placeholder="+27..." />
          <div class="field-line"></div>
        </div>
        <div class="form-field">
          <label>SERVICE NEEDED</label>
          <input type="text" placeholder="e.g. Residential pest control" />
          <div class="field-line"></div>
        </div>
        <div class="form-field">
          <label>MESSAGE</label>
          <textarea rows="3" placeholder="Tell us about your pest problem..."></textarea>
          <div class="field-line"></div>
        </div>
        <button type="submit" class="submit-btn">SEND REQUEST</button>
      </form>

      <!-- Social Links -->
      <div class="social-links">
        <a href="#" class="social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          <span>Facebook</span>
        </a>
        <a href="#" class="social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          <span>Twitter / X</span>
        </a>
        <a href="#" class="social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href="#" class="social-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L2 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <span>WhatsApp</span>
        </a>
      </div>
    </div>
    <div class="contact-image" style="background-image: url('https://images.unsplash.com/photo-1585429514710-67f0ece1226e?w=800&q=80')"></div>
  </section>

  <!-- Footer Border Pattern -->
  <div class="footer-border-gradient"></div>

  <Footer />
</Layout>

<style>
  .nav-divider { height: 1px; background: var(--surface-linen); }

  .contact-main {
    display: flex;
    gap: 80px;
    padding: 80px;
  }

  .contact-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .contact-heading { font-family: var(--font-display); font-size: 48px; color: var(--text-primary); line-height: 1.15; font-weight: 400; }
  .contact-subtitle { font-family: var(--font-body); font-size: 17px; font-weight: 300; color: var(--text-secondary); line-height: 1.7; }

  .dot-accent { display: flex; gap: 8px; }
  .dot { width: 6px; height: 6px; border-radius: 50%; }
  .dot.gold { background: var(--accent-gold); }
  .dot.terracotta { background: var(--accent-terracotta); }

  .contact-gold-line { width: 60px; height: 2px; background: var(--accent-gold); }

  .contact-info-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--surface-linen);
    padding: 20px 24px;
    border-radius: var(--radius-sm);
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--text-secondary);
  }

  .info-row span { font-family: var(--font-body); font-size: 14px; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-field label {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    color: var(--text-secondary);
  }

  .form-field input, .form-field textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-primary);
    background: transparent;
    border: none;
    outline: none;
    padding: 4px 0;
    resize: none;
  }

  .form-field input::placeholder, .form-field textarea::placeholder {
    color: var(--text-secondary);
    opacity: 0.5;
  }

  .field-line { height: 1px; background: var(--accent-gold); }

  .submit-btn {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--white);
    background: var(--accent-gold);
    border: none;
    padding: 16px 48px;
    cursor: pointer;
    align-self: flex-start;
    transition: opacity 0.3s;
  }

  .submit-btn:hover { opacity: 0.9; }

  .social-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    transition: color 0.3s;
  }

  .social-link span { font-family: var(--font-body); font-size: 13px; }
  .social-link:hover { color: var(--accent-gold); }

  .contact-image {
    width: 500px;
    flex-shrink: 0;
    background-size: cover;
    background-position: center;
    min-height: 600px;
  }

  .footer-border-gradient {
    height: 3px;
    background: linear-gradient(90deg, var(--accent-gold), var(--accent-terracotta) 50%, var(--accent-gold));
  }

  @media (max-width: 768px) {
    .contact-main { flex-direction: column; padding: 48px 24px; gap: 40px; }
    .contact-image { width: 100%; min-height: 300px; }
    .contact-heading { font-size: 32px; }
  }
</style>
