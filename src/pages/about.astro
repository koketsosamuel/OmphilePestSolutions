---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About – Omphile Pest Solutions">
  <Navbar activePage="about" />
  <div class="nav-divider"></div>

  <!-- Hero Section -->
  <section class="about-hero">
    <div class="about-portrait" style="background-image: url('https://images.unsplash.com/photo-1632935190593-e18460fa1534?w=800&q=80')"></div>
    <div class="about-bio">
      <span class="bio-tag">ABOUT US</span>
      <h1 class="bio-heading">A Legacy of Protection</h1>
      <p class="bio-para">
        Founded with a mission to safeguard homes and businesses across South Africa, Omphile Pest Solutions has grown from a small family operation into a trusted name in professional pest management. We combine modern techniques with deep local knowledge to deliver results you can count on.
      </p>
      <div class="bio-gold-line"></div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="stat">
      <span class="stat-label">EXPERIENCE</span>
      <span class="stat-value">15+ Years</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-label">COVERAGE</span>
      <span class="stat-value">Gauteng & Beyond</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-label">CLIENTS SERVED</span>
      <span class="stat-value">5,000+</span>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="highlights">
    <div class="highlights-header">
      <h2 class="highlights-title">Why Choose Us</h2>
      <span class="highlights-tag">OUR DIFFERENCE</span>
    </div>
    <div class="highlights-strip">
      <div class="highlight-card">
        <div class="highlight-img" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=400&q=80')"></div>
      </div>
      <div class="highlight-card">
        <div class="highlight-img" style="background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=400&q=80')"></div>
      </div>
      <div class="highlight-card">
        <div class="highlight-img" style="background-image: url('https://images.unsplash.com/photo-1585314062340-f1a5a7c9328d?w=400&q=80')"></div>
      </div>
      <div class="highlight-card">
        <div class="highlight-img" style="background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=400&q=80')"></div>
      </div>
      <div class="highlight-card">
        <div class="highlight-img" style="background-image: url('https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=400&q=80')"></div>
      </div>
    </div>
    <div class="highlights-labels">
      <div class="highlight-label">
        <h4>Eco-Friendly Solutions</h4>
        <p>Safe for your family & pets</p>
      </div>
      <div class="highlight-label">
        <h4>Licensed Professionals</h4>
        <p>Certified & insured technicians</p>
      </div>
      <div class="highlight-label">
        <h4>Guaranteed Results</h4>
        <p>Follow-up treatments included</p>
      </div>
      <div class="highlight-label">
        <h4>24/7 Emergency</h4>
        <p>Rapid response when you need it</p>
      </div>
      <div class="highlight-label">
        <h4>Custom Plans</h4>
        <p>Tailored to your property</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .nav-divider { height: 1px; background: var(--surface-linen); }

  .about-hero { display: flex; height: 720px; }
  .about-portrait { flex: 0 0 620px; background-size: cover; background-position: center; }

  .about-bio {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    padding: 80px 64px;
    background: var(--bg-ivory);
  }

  .bio-tag { font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: 2px; color: var(--accent-gold); }
  .bio-heading { font-family: var(--font-display); font-size: 42px; font-weight: 400; color: var(--text-primary); line-height: 1.15; }
  .bio-para { font-family: var(--font-body); font-size: 16px; color: var(--text-secondary); line-height: 1.7; }
  .bio-gold-line { width: 60px; height: 2px; background: var(--accent-gold); }

  .stats-section {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 48px 56px;
    background: var(--surface-linen);
  }

  .stat { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .stat-label { font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 2px; color: var(--accent-gold); }
  .stat-value { font-family: var(--font-display); font-size: 28px; color: var(--text-primary); font-weight: 400; }
  .stat-divider { width: 1px; height: 48px; background: var(--accent-gold); opacity: 0.3; }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 64px 56px;
    background: var(--bg-ivory);
  }

  .highlights-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .highlights-title { font-family: var(--font-display); font-size: 28px; color: var(--text-primary); font-weight: 400; }
  .highlights-tag { font-family: var(--font-body); font-size: 11px; font-weight: 600; letter-spacing: 2px; color: var(--accent-gold); }

  .highlights-strip {
    display: flex;
    gap: 16px;
    overflow: hidden;
    height: 280px;
  }

  .highlight-card { width: 220px; flex-shrink: 0; }
  .highlight-img { width: 100%; height: 100%; background-size: cover; background-position: center; }

  .highlights-labels {
    display: flex;
    gap: 16px;
  }

  .highlight-label {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .highlight-label h4 { font-family: var(--font-display); font-size: 16px; color: var(--text-primary); font-weight: 400; }
  .highlight-label p { font-family: var(--font-body); font-size: 12px; color: var(--text-secondary); }

  @media (max-width: 768px) {
    .about-hero { flex-direction: column; height: auto; }
    .about-portrait { flex: none; width: 100%; height: 400px; }
    .about-bio { padding: 48px 24px; }
    .bio-heading { font-size: 32px; }
    .stats-section { flex-direction: column; gap: 32px; padding: 48px 24px; }
    .stat-divider { width: 48px; height: 1px; }
    .highlights { padding: 48px 24px; }
    .highlights-strip { overflow-x: auto; }
    .highlights-labels { overflow-x: auto; }
  }
</style>
