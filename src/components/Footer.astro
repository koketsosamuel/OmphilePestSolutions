---
import { footerLegalNav, primaryNav } from '../data/navigation';
import { services } from '../data/services';
import { site } from '../data/site';
---

<!-- Footer -->
<footer class="footer">
  <div class="container">
  <div class="footer-cols">
    <div class="footer-brand">
      <img src="/Logo.png" alt="Omphile Pest Solutions" style="height:48px;width:auto;align-self:flex-start;" />
      <p class="footer-tagline">Professional pest control for homes, businesses, farms, and government facilities across South Africa.</p>
      <div class="footer-social">
        <a href="https://www.facebook.com/share/1Dyey1af1A/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
      </div>
    </div>
    <div class="footer-col">
      <h4>QUICK LINKS</h4>
      {primaryNav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
      <a href="/legal/">Legal</a>
    </div>
    <div class="footer-col">
      <h4>SERVICES</h4>
      {services.slice(0, 6).map((service) => (
        <a href={`/services/#${service.slug}`}>{service.title}</a>
      ))}
      <a href="/services/" class="footer-all">All Services &rarr;</a>
    </div>
    <div class="footer-col">
      <h4>CONTACT</h4>
      <a class="footer-contact-row" href={`tel:${site.phone}`}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg><span>{site.phoneDisplay}</span></a>
      <a class="footer-contact-row" href={site.whatsapp} target="_blank" rel="noopener noreferrer"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L2 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg><span>WhatsApp {site.phoneDisplay}</span></a>
      <a class="footer-contact-row" href={`mailto:${site.email}`}><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><span>{site.email}</span></a>
      <div class="footer-contact-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span>{site.location}</span></div>
      <div class="footer-contact-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 2h4"/><path d="M12 14v-4"/><path d="M4 13a8 8 0 0 1 8-7 8 8 0 1 1-5.3 14L4 13"/><path d="M9 17H4v5"/></svg><span>{site.hours}</span></div>
    </div>
  </div>
  <div class="footer-divider"></div>
  <div class="footer-bottom">
    <span class="footer-copyright">&copy; 2026 Omphile Pest Solutions. All rights reserved.</span>
    <div class="footer-policy-links">
      {footerLegalNav.map((item, index) => (
        <>
          <a href={item.href}>{item.label}</a>
          {index < footerLegalNav.length - 1 && <span class="footer-policy-sep">&middot;</span>}
        </>
      ))}
    </div>
    <div class="footer-badges">
      <span>B-BBEE Level 1</span>
      <span>SAPCA Registered</span>
    </div>
  </div>
  </div>
</footer>
