---
---

<footer class="footer">
  <div class="footer-border">
    {Array.from({ length: 8 }).map((_, i) => (
      <div class:list={['border-seg', i % 2 === 0 ? 'gold' : 'terracotta']} />
    ))}
  </div>
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">OMPHILE PEST SOLUTIONS</span>
        <p class="footer-tagline">Professional pest control<br>you can trust</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">Company</span>
          <a href="/about">About</a>
          <a href="/services">Services</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Connect</span>
          <a href="#">Facebook</a>
          <a href="#">WhatsApp</a>
          <a href="#">LinkedIn</a>
        </div>
      </div>
      <div class="footer-social">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <p class="copyright">&copy; 2026 Omphile Pest Solutions. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--accent-indigo);
    display: flex;
    flex-direction: column;
  }

  .footer-border {
    display: flex;
    height: 4px;
  }

  .border-seg {
    flex: 1;
    height: 4px;
  }

  .border-seg.gold { background: var(--accent-gold); }
  .border-seg.terracotta { background: var(--accent-terracotta); }

  .footer-content {
    padding: 48px 56px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 48px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 20px;
    color: #FAF6F0;
    letter-spacing: 1px;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(250, 246, 240, 0.67);
    line-height: 1.5;
  }

  .footer-links {
    display: flex;
    gap: 48px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-col-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--accent-gold);
    text-transform: uppercase;
  }

  .footer-col a {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(250, 246, 240, 0.8);
    transition: color 0.3s;
  }

  .footer-col a:hover {
    color: var(--accent-gold);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 16px;
    color: rgba(250, 246, 240, 0.8);
  }

  .footer-social svg {
    cursor: pointer;
    transition: color 0.3s;
  }

  .footer-social svg:hover {
    color: var(--accent-gold);
  }

  .footer-divider {
    height: 1px;
    background: rgba(250, 246, 240, 0.08);
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
  }

  .copyright {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(250, 246, 240, 0.38);
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: 32px 24px;
    }

    .footer-top {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
