  {slug === 'rodent-control' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 16.5a2.5 2.5 0 0 0-5 0"/><path d="M3 2c.1 3.3 1.2 6.5 3 9.3"/><path d="M9 7.5c.8.8 1.4 1.8 1.8 2.8"/><path d="M21 2c-.1 3.3-1.2 6.5-3 9.3"/><path d="M15 7.5c-.8.8-1.4 1.8-1.8 2.8"/><path d="M12 13c-1 0-2 .4-2.7 1.1"/><path d="M12 13c1 0 2 .4 2.7 1.1"/><path d="M8.5 16.5c0 .8.1 1.6.4 2.3"/><path d="M15.5 16.5c0 .8-.1 1.6-.4 2.3"/><path d="M9 22h6"/></svg>
  )}
  {slug === 'mosquito-fly-control' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
  )}
  {slug === 'bed-bug-treatment' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
  )}
  {slug === 'bird-control' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 7h.01"/><path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/><path d="m20 7 2 .5-2 .5"/><path d="M10 18v3"/><path d="M14 17.75V21"/><path d="M7 18a6 6 0 0 0 3.84-10.61"/></svg>
  )}
  {slug === 'fumigation' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 1 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/></svg>
  )}
  {slug === 'weed-vegetation-control' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>
  )}
  {slug === 'lawn-garden-pests' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 7.5a4.5 4.5 0 1 1 4.5 4.5M12 7.5A4.5 4.5 0 1 0 7.5 12M12 7.5V9m-4.5 3H9"/><path d="M7.5 12a4.5 4.5 0 1 0 4.5 4.5M7.5 12H9"/><path d="M12 16.5a4.5 4.5 0 1 1 4.5-4.5M12 16.5V15"/><path d="M16.5 12a4.5 4.5 0 1 0-4.5-4.5M16.5 12H15"/></svg>
  )}
  {slug === 'sanitation-services' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
  )}
  {slug === 'government-contract-services' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
  )}
</span>

<style>
  .service-icon {
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(27, 58, 45, .06);
    border-radius: 8px;
    color: var(--primary-deep-forest);
    flex-shrink: 0;
  }
  .service-icon svg {
    width: 28px;
    height: 28px;
  }
</style>
