<!-- Nav Bar -->
<nav class="navbar">
  <div class="container">
  <div class="nav-left">
    <a href="/" style="display:flex;align-items:center;">
      <img src="/Logo.png" alt="Omphile Pest Solutions" style="height:40px;width:auto;" />
    </a>
  </div>
  <div class="mobile-menu">
    <div class="nav-links">
      <a href="/" class="nav-link">Home</a>
      <a href="/#services" class="nav-link">Services</a>
      <a href="/#about" class="nav-link">About</a>
      <a href="/#areas" class="nav-link">Areas We Cover</a>
      <a href="/#faq" class="nav-link">FAQ</a>
      <a href="/#quote" class="nav-link">Contact Us</a>
    </div>
  </div>
  <button class="nav-toggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const menu = document.querySelector('.mobile-menu');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    menu?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (menu?.classList.contains('open') && !menu.contains(e.target as Node) && e.target !== toggle) {
      menu.classList.remove('open');
    }
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.remove('open'));
  });
</script>
