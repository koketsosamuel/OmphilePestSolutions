{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "omphile-pest-solutions",
  "compatibility_date": "2026-04-22",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "pestsolutions.omphilebotshelo.co.za",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
